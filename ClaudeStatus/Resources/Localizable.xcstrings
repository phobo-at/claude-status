{
  "sourceLanguage" : "en",
  "strings" : {
    "Access to the Claude Code login was denied." : {
      "comment" : "Error shown when the user denies the Keychain dialog.",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Der Zugriff auf den Claude-Code-Login wurde nicht erlaubt."
          }
        }
      }
    },
    "After you allow it, Claude Status reads your existing Claude Code login from the macOS Keychain once per app launch. It then stays in memory only, and is never stored or logged." : {
      "comment" : "First-run consent text on the connect screen.",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Claude Status liest nach deiner Freigabe den vorhandenen Claude-Code-Login einmal pro App-Start aus dem macOS-Schlüsselbund. Danach bleibt er nur im Arbeitsspeicher und wird weder gespeichert noch protokolliert."
          }
        }
      }
    },
    "All models" : {
      "comment" : "Title of the weekly all-models limit row.",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Alle Modelle"
          }
        }
      }
    },
    "Check again" : {
      "comment" : "Button that re-checks the login after the user ran claude auth login.",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Erneut prüfen"
          }
        }
      }
    },
    "Claude is temporarily unavailable (HTTP %lld)." : {
      "comment" : "Error for a 5xx response. Placeholder is the HTTP status code.",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Claude ist vorübergehend nicht erreichbar (HTTP %lld)."
          }
        }
      }
    },
    "Claude received too many refreshes." : {
      "comment" : "Error for HTTP 429, the account-scoped rate limit.",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Claude hat zu viele Aktualisierungen erhalten."
          }
        }
      }
    },
    "Claude returned no usage limits." : {
      "comment" : "Error when the payload decodes but carries no limit windows.",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Claude hat keine Nutzungslimits zurückgegeben."
          }
        }
      }
    },
    "Claude sent an unexpected response." : {
      "comment" : "Error for an undecodable or unexpected response.",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Claude hat eine unerwartete Antwort gesendet."
          }
        }
      }
    },
    "Claude sign-in required" : {
      "comment" : "Headline when the login is missing or expired.",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Claude-Anmeldung erforderlich"
          }
        }
      }
    },
    "Claude usage unavailable" : {
      "comment" : "Menu-bar accessibility label when no usage data is available.",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Claude-Nutzung nicht verfügbar"
          }
        }
      }
    },
    "Claude usage, current session: %@ used" : {
      "comment" : "Menu-bar accessibility label. Placeholder is a formatted percentage.",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Claude-Nutzung, aktuelle Sitzung: %@ verwendet"
          }
        }
      }
    },
    "Connect to Claude Code" : {
      "comment" : "Label and button on the first-run connect screen.",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mit Claude Code verbinden"
          }
        }
      }
    },
    "Copied" : {
      "comment" : "Confirmation shown on the copy button after copying.",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kopiert"
          }
        }
      }
    },
    "Copy claude auth login" : {
      "comment" : "Button that copies the literal command 'claude auth login' to the clipboard.",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "claude auth login kopieren"
          }
        }
      }
    },
